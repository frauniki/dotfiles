#!/bin/bash

# バックアップスクリプト
# 使用法: ./backup_script.sh <対象ディレクトリ> <バックアップ先ディレクトリ>

# 引数チェック
if [ $# -ne 2 ]; then
    echo "使用法: $0 <対象ディレクトリ> <バックアップ先ディレクトリ>"
    echo "例: $0 /home/user/documents /backup/location"
    exit 1
fi

SOURCE_DIR="$1"
BACKUP_DIR="$2"

# 対象ディレクトリの存在確認
if [ ! -d "$SOURCE_DIR" ]; then
    echo "エラー: 対象ディレクトリ '$SOURCE_DIR' が存在しません"
    exit 1
fi

# バックアップ先ディレクトリの作成（存在しない場合）
if [ ! -d "$BACKUP_DIR" ]; then
    echo "バックアップ先ディレクトリを作成します: $BACKUP_DIR"
    mkdir -p "$BACKUP_DIR"
    if [ $? -ne 0 ]; then
        echo "エラー: バックアップ先ディレクトリの作成に失敗しました"
        exit 1
    fi
fi

# アーカイブファイル名の生成（タイムスタンプ付き）
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
SOURCE_BASENAME=$(basename "$SOURCE_DIR")
ARCHIVE_NAME="${SOURCE_BASENAME}_${TIMESTAMP}.tar.gz"
ARCHIVE_PATH="${BACKUP_DIR}/${ARCHIVE_NAME}"

echo "=== バックアップ開始 $(date '+%Y-%m-%d %H:%M:%S') ==="
echo "対象ディレクトリ: $SOURCE_DIR"
echo "バックアップ先: $BACKUP_DIR"
echo "アーカイブファイル: $ARCHIVE_NAME"
echo ""

# チェックサム計算
echo "ディレクトリのチェックサムを計算中..."
CHECKSUM_FILE="$BACKUP_DIR/.${SOURCE_BASENAME}_checksum"

# 現在のディレクトリのチェックサムを計算（.gitignoreを考慮）
calculate_checksum() {
    # 一時的にシンプルなfind + checksumで計算
    find "$SOURCE_DIR" -type f \
        ! -path "*/.git/*" \
        ! -path "*/node_modules/*" \
        ! -name ".DS_Store" \
        -exec /sbin/md5 {} + 2>/dev/null | \
        sort | \
        /sbin/md5 | \
        cut -d' ' -f1
}

CURRENT_CHECKSUM=$(calculate_checksum)
echo "現在のチェックサム: $CURRENT_CHECKSUM"

# 前回のチェックサムと比較
if [ -f "$CHECKSUM_FILE" ]; then
    LAST_CHECKSUM=$(cat "$CHECKSUM_FILE")
    echo "前回のチェックサム: $LAST_CHECKSUM"
    
    if [ "$CURRENT_CHECKSUM" = "$LAST_CHECKSUM" ]; then
        echo "✓ ディレクトリに変更がありません。バックアップをスキップします。"
        echo ""
        echo "=== バックアップスキップ $(date '+%Y-%m-%d %H:%M:%S') ==="
        exit 0
    else
        echo "変更が検出されました。バックアップを実行します。"
    fi
else
    echo "初回バックアップです。"
fi
echo ""

# tar.gzアーカイブの作成
echo "アーカイブを作成中..."

# まずルートの.gitignoreを処理して除外パターンを取得
TEMP_EXCLUDE_FILE=$(mktemp)
ROOT_GITIGNORE="$SOURCE_DIR/.gitignore"

# SOURCE_DIRを絶対パスに正規化
SOURCE_DIR_ABS=$(cd "$SOURCE_DIR" && pwd)

if [ -f "$ROOT_GITIGNORE" ]; then
    echo "ルートの.gitignoreファイルを処理中: $ROOT_GITIGNORE"
    while IFS= read -r pattern; do
        case "$pattern" in
            \#*|"") continue ;;
        esac
        echo "$pattern" >> "$TEMP_EXCLUDE_FILE"
        echo "  除外パターン追加: $pattern"
    done < "$ROOT_GITIGNORE"
fi

# 除外されていないディレクトリ内の.gitignoreファイルを検索
OTHER_GITIGNORES=$(find "$SOURCE_DIR_ABS" -name ".gitignore" -type f ! -path "$ROOT_GITIGNORE")

if [ -n "$OTHER_GITIGNORES" ]; then
    echo "サブディレクトリの.gitignoreファイルを処理中..."
    
    for gitignore_file in $OTHER_GITIGNORES; do
        # このディレクトリが除外対象かチェック
        gitignore_dir=$(dirname "$gitignore_file")
        
        # 相対パスを正しく計算
        case "$gitignore_dir" in
            "$SOURCE_DIR_ABS")
                relative_dir="."
                ;;
            "$SOURCE_DIR_ABS"/*)
                relative_dir="${gitignore_dir#$SOURCE_DIR_ABS/}"
                ;;
            *)
                echo "警告: 予期しないパス: $gitignore_dir"
                continue
                ;;
        esac
        
        # 除外対象でないかチェック
        is_excluded=false
        if [ -f "$TEMP_EXCLUDE_FILE" ] && [ "$relative_dir" != "." ]; then
            while IFS= read -r exclude_pattern; do
                case "$relative_dir" in
                    $exclude_pattern|$exclude_pattern/*) 
                        is_excluded=true
                        echo "  スキップ（$exclude_pattern で除外）: $gitignore_file"
                        break
                        ;;
                esac
            done < "$TEMP_EXCLUDE_FILE"
        fi
        
        if [ "$is_excluded" = "false" ]; then
            echo "  処理中: $gitignore_file (相対パス: $relative_dir)"
            
            # .gitignoreのパターンを処理
            while IFS= read -r pattern; do
                case "$pattern" in
                    \#*|"") continue ;;
                esac
                
                if [ "$relative_dir" = "." ]; then
                    echo "$pattern" >> "$TEMP_EXCLUDE_FILE"
                    echo "    除外パターン追加: $pattern"
                else
                    echo "$relative_dir/$pattern" >> "$TEMP_EXCLUDE_FILE"
                    echo "    除外パターン追加: $relative_dir/$pattern"
                fi
            done < "$gitignore_file"
        fi
    done
fi

# デバッグ: 最終的な除外パターンを表示
echo ""
echo "最終的な除外パターン:"
if [ -f "$TEMP_EXCLUDE_FILE" ]; then
    cat "$TEMP_EXCLUDE_FILE"
    echo ""
fi

# 重複除去
if [ -f "$TEMP_EXCLUDE_FILE" ]; then
    sort -u "$TEMP_EXCLUDE_FILE" > "${TEMP_EXCLUDE_FILE}.sorted"
    mv "${TEMP_EXCLUDE_FILE}.sorted" "$TEMP_EXCLUDE_FILE"
    EXCLUDE_OPTS="--exclude-vcs --exclude-from=$TEMP_EXCLUDE_FILE"
else
    EXCLUDE_OPTS="--exclude-vcs"
fi

# tarコマンド実行
tar -czf "$ARCHIVE_PATH" $EXCLUDE_OPTS -C "$(dirname "$SOURCE_DIR")" "$(basename "$SOURCE_DIR")"
TAR_RESULT=$?

# 一時ファイルのクリーンアップ
if [ -n "$TEMP_EXCLUDE_FILE" ] && [ -f "$TEMP_EXCLUDE_FILE" ]; then
    rm -f "$TEMP_EXCLUDE_FILE"
fi

# 結果確認
if [ $TAR_RESULT -eq 0 ]; then
    # ファイルサイズの取得
    if command -v du >/dev/null 2>&1; then
        ARCHIVE_SIZE=$(du -h "$ARCHIVE_PATH" | cut -f1)
        echo "✓ バックアップが正常に完了しました"
        echo "  アーカイブファイル: $ARCHIVE_PATH"
        echo "  ファイルサイズ: $ARCHIVE_SIZE"
    else
        echo "✓ バックアップが正常に完了しました"
        echo "  アーカイブファイル: $ARCHIVE_PATH"
    fi
    
    # 古いバックアップファイルのクリーンアップ
    echo ""
    echo "古いバックアップファイルをクリーンアップ中..."
    
    OLD_ARCHIVES=$(ls -t "$BACKUP_DIR"/${SOURCE_BASENAME}_*.tar.gz 2>/dev/null | tail -n +21)
    
    if [ -n "$OLD_ARCHIVES" ]; then
        echo "以下のファイルを削除します:"
        for file in $OLD_ARCHIVES; do
            echo "  - $(basename "$file")"
            rm -f "$file"
        done
        echo "✓ 古いバックアップファイルを削除しました"
    else
        echo "削除対象のファイルはありません"
    fi
    
    echo ""
    echo "=== バックアップ完了 $(date '+%Y-%m-%d %H:%M:%S') ==="
    
    # チェックサムを保存
    echo "$CURRENT_CHECKSUM" > "$CHECKSUM_FILE"
    echo "チェックサムを保存しました: $CHECKSUM_FILE"
else
    echo "✗ エラー: バックアップに失敗しました"
    exit 1
fi
